{
  "name": "bace",
  "version": "2.0.0",
  "description": "Aplicación BACE Electron",
  "main": "electron/index.js",
  "author": "Luis Rodriguez",
  "license": "ISC",
  "scripts": {
    "dev": "electron ./electron",
    "devg": "concurrently -k --success first \"npm run dev\" \"cd renderer && npm run dev\"",
    "build": "cd renderer && npm run build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win"
  },
  "keywords": [],
  "devDependencies": {
    "@electron/rebuild": "3.2.13",
    "concurrently": "^8.2.2",
    "electron": "22.3.9",
    "electron-builder": "22.13.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^9.6.0"
  },
  "build": {
    "appId": "com.bace.electron",
    "productName": "BACE",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BACE",
      "perMachine": false,
      "allowElevation": true
    }
  }
}
