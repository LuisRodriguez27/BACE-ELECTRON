{
  "name": "bace",
  "version": "4.1.1",
  "description": "Aplicación BACE Electron",
  "main": "electron/index.js",
  "author": "Luis Rodriguez",
  "license": "ISC",
  "scripts": {
    "postinstall": "",
    "dev:electron": "electron ./electron --no-sandbox",
    "dev": "concurrently -k --success first \"pnpm run dev:electron\" \"cd renderer && pnpm run dev\"",
    "build": "cd renderer && pnpm run build",
    "dist": "pnpm run build && electron-builder",
    "dist:win": "pnpm run build && electron-builder --win"
  },
  "keywords": [],
  "packageManager": "pnpm@10.29.1",
  "devDependencies": {
    "@electron/rebuild": "4.0.1",
    "concurrently": "^9.2.0",
    "electron": "37.3.0",
    "electron-builder": "^26.0.12",
    "jscodeshift": "^17.3.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.3.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.4",
    "mime-types": "^3.0.2",
    "pg": "^8.19.0",
    "uuid": "^13.0.0"
  },
  "build": {
    "appId": "com.bace.electron",
    "publish": {
      "provider": "github",
      "owner": "LuisRodriguez27",
      "repo": "BACE-ELECTRON"
    },
    "productName": "BACE",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "node_modules/**/*",
      ".env",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BACE"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}