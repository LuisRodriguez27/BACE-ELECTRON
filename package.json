{
  "name": "bace",
  "version": "1.0.0",
  "description": "Aplicación BACE Electron",
  "main": "electron/index.js",
  "author": "Luis Rodriguez",
  "license": "ISC",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "electron ./electron",
    "rebuild": "electron-rebuild -f -w better-sqlite3 --version 37.3.0",
    "frebuild": "electron-rebuild",
    "devg": "concurrently \"npm run dev\" \"cd renderer && npm run dev\"",
    "buildg": "cd renderer && npm run build electron-rebuild",
    "build": "cd renderer && npm run build",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "devDependencies": {
    "@electron/rebuild": "4.0.1",
    "concurrently": "^9.2.0",
    "electron": "37.3.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.2.0"
  },
  "build": {
    "appId": "com.bace.electron",
    "productName": "BACE",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BACE"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    }
  }
}
