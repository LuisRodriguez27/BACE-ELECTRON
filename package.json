{
  "name": "bace",
  "version": "4.0.0",
  "description": "Aplicación BACE Electron",
  "main": "electron/index.js",
  "author": "Luis Rodriguez",
  "license": "ISC",
  "scripts": {
    "postinstall": "",
    "dev:electron": "electron ./electron --no-sandbox",
    "dev": "concurrently -k --success first \"pnpm run dev:electron\" \"cd renderer && pnpm run dev\"",
    "build": "cd renderer && pnpm run build",
    "dist": "pnpm run build && electron-builder",
    "dist:win": "pnpm run build && electron-builder --win"
  },
  "keywords": [],
  "packageManager": "pnpm@10.29.1",
  "devDependencies": {
    "@electron/rebuild": "3.2.13",
    "concurrently": "^8.2.2",
    "electron": "22.3.9",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.5",
    "fs-extra": "^11.1.1",
    "mime-types": "^2.1.35",
    "pg": "^8.11.5",
    "uuid": "^9.0.1"
  },
  "build": {
    "appId": "com.bace.electron",
    "productName": "BACE",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "node_modules/**/*",
      ".env",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BACE"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}